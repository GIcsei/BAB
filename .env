APP_USER_DATA_DIR="/var/app/user_data" # Location of user data where the app stores user-specific information (e.g. browser profiles, cookies, etc.)
LOCAL_DOWNLOADS_DIR="/var/app/downloads" # Location where the app saves downloaded files. This should be a directory that is accessible to the app and has sufficient storage space for downloads.
# APP_PORT=8080
SELENIUM_DOWNLOADS_DIR="/home/seluser/Downloads" # Location where Selenium saves downloaded files. This should be a directory that is accessible to the Selenium container. Only used to volume mount the Selenium downloads directory to the host, so that downloaded files can be accessed outside of the Selenium container.

# TrueNAS SCALE defaults
PUID=1200 # User ID for the app container.
PGID=1201 # Group ID for the app container.
APP_PORT=7979 # Port on which the app will run.

# Required host paths (datasets) on your NAS
APP_USER_DATA_HOST_PATH=/home/geri/bab_store/user_data # Host path for user data. This should be a directory on your NAS where the app can store user-specific information (e.g. browser profiles, cookies, etc.). Make sure this directory has appropriate permissions for the app to read/write data. Linked to APP_USER_DATA_DIR in the container.
APP_DOWNLOADS_HOST_PATH=/home/geri/bab_store/downloads # Host path for downloads. This should be a directory on your NAS where the app can save downloaded files. Make sure this directory has appropriate permissions for the app to read/write data. Linked to LOCAL_DOWNLOADS_DIR in the container.
# App scheduler/logging
APP_JOB_HOUR=18 # Hour of the day when the app's scheduled job will run (0-23). Set to 18 for 6 PM.
APP_JOB_MINUTE=0 # Minute of the hour when the app's scheduled job will run (0-59). Set to 0 for the top of the hour.

# Required secret for credential encryption
FIRESTORE_MASTER_KEY="/home/geri/bab_store/master.json" # Host path to the master key file used for encrypting credentials stored in Firestore.
FIRESTORE_CREDENTIALS=/var/app/credentials.json # Path to the credentials file used for accessing Firestore.

# Logging configuration
LOG_LEVEL=INFO # Logging level for the app (e.g. DEBUG, INFO, WARNING, ERROR, CRITICAL). Set to INFO for general logging.
LOG_FILE=/var/app/app.log # Path to the log file where the app will write logs. Make sure this file is writable by the app.
LOG_JSON=true # Whether to log in JSON format. Set to true for structured logging that can be easily parsed by log management systems. WARNING: Enabling JSON logging may make logs less human-readable when viewed directly, but it allows for better integration with log management tools that can parse JSON logs.



