# ── Application paths ────────────────────────────────────────────────
APP_USER_DATA_DIR="/var/app/user_data"      # Container path for user-specific data
LOCAL_DOWNLOADS_DIR="/var/app/downloads"     # Container path for downloaded files
# APP_PORT=8080
SELENIUM_DOWNLOADS_DIR="/home/seluser/Downloads"  # Selenium download path (container)

# ── TrueNAS SCALE defaults ──────────────────────────────────────────
PUID=1000                                   # Host user ID for file ownership
PGID=1000                                   # Host group ID for file ownership
APP_PORT=7979                               # Port the app listens on

# ── Host paths (datasets on your NAS) ───────────────────────────────
APP_USER_DATA_HOST_PATH=/path/to/user_data  # Host directory for user data
APP_DOWNLOADS_HOST_PATH=/path/to/downloads  # Host directory for downloads

# ── Scheduler / logging ─────────────────────────────────────────────
APP_JOB_HOUR=18                             # Hour (0-23) for the daily scheduled job
APP_JOB_MINUTE=0                            # Minute (0-59) for the daily scheduled job

# ── Firebase / Firestore credentials ────────────────────────────────
FIRESTORE_MASTER_KEY="/path/to/master.json" # Host path to the Firestore master key
FIRESTORE_CREDENTIALS=/var/app/credentials.json  # Container path to service-account JSON
# FIREBASE_API_KEY=                         # Firebase Web API key (set in production)

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FILE=/var/app/app.log                   # Container path for the log file
LOG_JSON=false                              # true for structured JSON logs
