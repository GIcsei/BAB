# TrueNAS SCALE defaults
APP_PORT=6767
PUID=568
PGID=568

# Required host paths (datasets) on your NAS
# These must point to existing directories with correct permissions
APP_USER_DATA_HOST_PATH=/mnt/tank/apps/bab/user_data
APP_DOWNLOADS_HOST_PATH=/mnt/tank/apps/bab/downloads

# App scheduler/logging
APP_JOB_HOUR=18
APP_JOB_MINUTE=0
LOG_LEVEL=INFO
LOG_JSON=false

# Selenium download directory inside the Selenium container
SELENIUM_DOWNLOADS_DIR=/home/seluser/Downloads

# Required: path to the Firestore service-account JSON on the host
FIRESTORE_MASTER_KEY=/mnt/tank/apps/bank-analysis/secrets/firestore.json
