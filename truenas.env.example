# TrueNAS SCALE defaults
APP_PORT=8000
PUID=568
PGID=568

# Required host paths (datasets) on your NAS
APP_USER_DATA_HOST_PATH=/mnt/tank/apps/bab/user_data
APP_DOWNLOADS_HOST_PATH=/mnt/tank/apps/bab/downloads
# App scheduler/logging
APP_JOB_HOUR=18
APP_JOB_MINUTE=0
LOG_LEVEL=INFO

# Required secret for credential encryption
NETBANK_MASTER_KEY=replace_me_with_32byte_urlsafe_base64_or_passphrase
